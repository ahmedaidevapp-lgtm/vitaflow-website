    { "population": "Adult females ≥50 years", "min": 0, "max": 30, "unit": "mm/hr", "source": "Mayo Clinic Laboratories (Westergren method)", "sourceUrl": "https://www.mayocliniclabs.com/test-catalog/overview/9387" }
